{
  "name": "rotunda",
  "version": "0.1.4",
  "description": "Bidirectional config sync tool with LLM-assisted review",
  "type": "module",
  "bin": {
    "rotunda": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node test/run.mjs test/**/*.test.ts",
    "test:unit": "node test/run.mjs test/unit/**/*.test.ts",
    "test:integration": "node test/run.mjs test/integration/**/*.test.ts",
    "lint": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dotfiles",
    "sync",
    "config",
    "bidirectional"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "minimatch": "^10.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
